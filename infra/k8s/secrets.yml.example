# Example Secrets for the raw Kubernetes manifests.
#
# Copy this file and fill in real values:
#   cp secrets.yml.example secrets.yml
#
# secrets.yml is gitignored — DO NOT commit it. The placeholders below
# (CHANGE_ME / <...>) are NOT valid; the Spring services and MongoDB will
# fail to start until you replace every one of them with a real value.
#
# How to fill each field
# ----------------------
# 1. mongodb-credentials / mongodb-user-credentials
#    - root-username / root-password: the MongoDB root user created on first
#      init. Choose a strong password.
#    - uri: the connection string each Spring service uses. Format:
#        mongodb://<root-username>:<root-password>@mongodb:27017/<db>?authSource=admin
#      content-service uses database "content"; user-service uses "users".
#      Keep the username/password in the URIs in sync with root-* above.
#
#    !! ROTATING root-password: MongoDB only applies the root password on the
#    FIRST init (empty data dir). If you change it while the mongodb-data PVC
#    still exists, Mongo keeps the OLD password and the services fail with
#    "Authentication failed". After changing it, wipe the volume so it
#    re-initializes (dev data is disposable):
#        kubectl delete deploy mongodb
#        kubectl delete pvc mongodb-data
#        kubectl apply -R -f .
#
# 2. jwt-keys (RSA key pair the user-service uses to sign JWTs)
#    All user-service replicas load the SAME key (and derive an identical JWK
#    kid from its thumbprint), so a token signed by one pod validates against
#    the JWKS served by any pod behind the Service. Generate a fresh pair:
#        openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt-private.pem
#        openssl pkey -in jwt-private.pem -pubout -out jwt-public.pem
#    Then paste the PEM contents below (keep the 4-space block indentation).
#
# For anything beyond local/dev, prefer a sealed-secret or external secret
# store (e.g. External Secrets Operator) over a plaintext file on disk.
#
# Two secrets exist so each service connects to its own database on the shared
# MongoDB instance:
#   - mongodb-credentials       -> content-service (database: content) + the mongod root user
#   - mongodb-user-credentials  -> user-service    (database: users)
apiVersion: v1
kind: Secret
metadata:
  name: mongodb-credentials
type: Opaque
stringData:
  root-username: CHANGE_ME
  root-password: CHANGE_ME
  uri: mongodb://CHANGE_ME:CHANGE_ME@mongodb:27017/content?authSource=admin
---
apiVersion: v1
kind: Secret
metadata:
  name: mongodb-user-credentials
type: Opaque
stringData:
  uri: mongodb://CHANGE_ME:CHANGE_ME@mongodb:27017/users?authSource=admin
---
apiVersion: v1
kind: Secret
metadata:
  name: jwt-keys
type: Opaque
stringData:
  public-key: |
    -----BEGIN PUBLIC KEY-----
    <PASTE jwt-public.pem CONTENTS HERE>
    -----END PUBLIC KEY-----
  private-key: |
    -----BEGIN PRIVATE KEY-----
    <PASTE jwt-private.pem CONTENTS HERE>
    -----END PRIVATE KEY-----
---
# Secret for user-service's client_credentials token used to call content-service's
# subscribe/unsubscribe endpoints (scope source.write). If you omit this Secret, remove the
# SERVICE_CLIENT_SECRET env from userservice-deployment.yml — subscriber-count sync then no-ops
# (security is unaffected; content-service still rejects user tokens). Generate: openssl rand -hex 32
apiVersion: v1
kind: Secret
metadata:
  name: service-credentials
type: Opaque
stringData:
  client-secret: CHANGE_ME
