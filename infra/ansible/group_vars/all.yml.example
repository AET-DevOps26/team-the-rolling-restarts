---
project_root: /opt/rolling-restarts

# Container registry (GHCR, Docker Hub, etc.)
registry: ghcr.io/aet-devops26/team-the-rolling-restarts
registry_user: ""
registry_token: ""
image_tag: latest

app_env:
  SPRING_PROFILES_ACTIVE: "production"
  CORS_ALLOWED_ORIGINS: "https://your-domain.example.com"
  LLM_PROVIDER: "ollama"
  LLM_BASE_URL: "https://logos.aet.cit.tum.de/v1"
  LLM_API_KEY: ""
  LLM_MODEL: "llama3.2"
  INTERNAL_API_URL: "http://api-gateway:8080"
  OLLAMA_BASE_URL: "http://ollama:11434"
  OLLAMA_PORT: "11434"
  LOG_LEVEL: "INFO"
  APP_PORT: "80"
  GEN_AI_PORT: "8000"
  MONGO_PORT: "27017"
  MONGO_DATABASE: "mydatabase"
  MONGO_ROOT_USERNAME: "root"
  MONGO_ROOT_PASSWORD: "replace-with-vault-secret"
  # Generate with: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -outform PEM
  # Then extract public key: openssl pkey -pubout
  JWT_RSA_PUBLIC_KEY: "replace-with-pem-public-key"
  JWT_RSA_PRIVATE_KEY: "replace-with-pem-private-key"
  SERVICE_CLIENT_SECRET: "replace-with-random-secret"
  LGTM_GRAFANA_PORT: "3001"
  LGTM_OTLP_GRPC_PORT: "4317"
  LGTM_OTLP_HTTP_PORT: "4318"
  # Grafana admin login, also reachable via the reverse proxy at /monitoring. Generate with:
  # openssl rand -hex 16
  GRAFANA_ADMIN_PASSWORD: "replace-with-vault-secret"
  # Alert email delivery. Any SMTP provider works; Gmail shown here as an example — generate an
  # App Password (requires 2FA) at myaccount.google.com/apppasswords, NOT the regular account
  # password. GRAFANA_ALERT_EMAILS is a comma-separated recipient list.
  GF_SMTP_HOST: "smtp.gmail.com:587"
  GRAFANA_SMTP_USER: "replace-with-sender-address"
  GRAFANA_SMTP_PASSWORD: "replace-with-vault-secret"
  GRAFANA_ALERT_EMAILS: "replace-with-recipient-list"
  # Externally reachable URL Grafana uses for absolute links it generates itself (e.g. the "View
  # alert rule" link in alert emails). Must match this VM's real public domain/IP, or those links
  # are dead for recipients. Include the /monitoring/ sub-path.
  GRAFANA_ROOT_URL: "https://your-domain.example.com/monitoring/"
