# Frontend/client (served via the reverse proxy at APP_PORT — no dedicated host port). Only used
# by the "test" compose profile's web-client-test service; infra/docker-compose.yaml itself
# hardcodes the correct per-target value directly (not read from this file) since it's a
# server-only setting (see web-client/src/lib/api/client.ts) baked in per deployment topology.
API_BASE_URL=http://localhost:8080

# Entry point (nginx reverse proxy)
APP_PORT=8080

# GenAI
GEN_AI_PORT=8000
LLM_PROVIDER=logos                 # logos | ollama
LLM_BASE_URL=https://logos.aet.cit.tum.de/v1
LLM_MODEL=openai/gpt-oss-120b
LLM_API_KEY=lg-your-logos-key-here # from your tutor; TUM network / eduVPN only
INTERNAL_API_URL=http://api-gateway:8080
# Local model (only when LLM_PROVIDER=ollama, compose profile local-llm)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_PORT=11434
LOG_LEVEL=INFO

# MongoDB
MONGO_PORT=27017
MONGO_DATABASE=mydatabase
MONGO_ROOT_USERNAME=root
MONGO_ROOT_PASSWORD=secret

# JWT signing keys (user-service auth server). Only needed for production-profile runs of the base
# compose file — the dev overlay (docker-compose.dev.yaml) supplies its own keys. If left empty,
# user-service falls back to an EPHEMERAL key pair that is regenerated on every restart, which
# invalidates all previously issued tokens. Provide a shared RSA pair as SINGLE-LINE PEMs (newlines
# stripped — markers and whitespace are ignored when the key is parsed). Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out jwt.pem
#   JWT_RSA_PRIVATE_KEY=$(tr -d '\n' < jwt.pem)
#   JWT_RSA_PUBLIC_KEY=$(openssl pkey -in jwt.pem -pubout | tr -d '\n')
JWT_RSA_PUBLIC_KEY=
JWT_RSA_PRIVATE_KEY=

# Shared secret for the client_credentials token user-service uses to call content-service's
# subscribe/unsubscribe endpoints (scope source.write). Defaults to a dev value in compose;
# set a strong value in production. Generate with: openssl rand -hex 32
SERVICE_CLIENT_SECRET=

# Comma-separated allowed CORS origins for the api-gateway. REQUIRED in production: if unset the
# gateway fails closed (allows no cross-origin requests). Example: https://news.example.com
CORS_ALLOWED_ORIGINS=

# Observability stack
LGTM_GRAFANA_PORT=3001
LGTM_OTLP_GRPC_PORT=4317
LGTM_OTLP_HTTP_PORT=4318
# Grafana admin login (also reachable via the reverse proxy at /monitoring, not just
# LGTM_GRAFANA_PORT directly). Defaults to "admin" if unset — set a real value outside local dev.
# Generate with: openssl rand -hex 16
GRAFANA_ADMIN_PASSWORD=

# Alert email delivery (Grafana's "Slow response time"/"Service down" rules, provisioned in
# infra/grafana/provisioning/alerting/). Any SMTP provider works; Gmail shown here as an example —
# generate an App Password (requires 2FA) at myaccount.google.com/apppasswords, do NOT use your
# regular account password.
GF_SMTP_HOST=smtp.gmail.com:587
GRAFANA_SMTP_USER=
GRAFANA_SMTP_PASSWORD=
# Comma-separated recipient list — replace here on any redeploy without touching provisioning YAML.
GRAFANA_ALERT_EMAILS=

# Dev container file-watching helper for some Linux setups
WATCHPACK_POLLING=false
