' ========================
' SEQUENCE DIAGRAM
' ========================
@startuml
title Sequence Diagram Example
Alice -> Bob: Hello
Bob --> Alice: Hi back
@enduml


' ========================
' USE CASE DIAGRAM
' ========================
@startuml
title Use Case Example
actor User
User --> (Login)
User --> (View Dashboard)
@enduml


' ========================
' CLASS DIAGRAM
' ========================
@startuml
title Class Diagram Example
class Animal {
  +name: String
  +eat()
}
class Dog {
  +bark()
}
Animal <|-- Dog
@enduml


' ========================
' ACTIVITY DIAGRAM
' ========================
@startuml
title Activity Diagram Example
start
:User logs in;
if (Valid?) then (yes)
  :Show dashboard;
else (no)
  :Show error;
endif
stop
@enduml


' ========================
' STATE DIAGRAM
' ========================
@startuml
title State Diagram Example
[*] --> Idle
Idle --> Processing : start
Processing --> Done : finish
Done --> [*]
@enduml


' ========================
' COMPONENT DIAGRAM
' ========================
@startuml
title Component Diagram Example
[Frontend] --> [Backend]
[Backend] --> [Database]
@enduml


' ========================
' DEPLOYMENT DIAGRAM
' ========================
@startuml
title Deployment Diagram Example
node "Server" {
  component "App"
}
node "DB Server" {
  database "Database"
}
"Server" --> "DB Server"
@enduml


' ========================
' OBJECT DIAGRAM
' ========================
@startuml
title Object Diagram Example
object user1 {
  name = "Alice"
}
object user2 {
  name = "Bob"
}
user1 --> user2 : knows
@enduml


' ========================
' TIMING DIAGRAM
' ========================
@startuml
title Timing Diagram Example
robust "System" as S
@0
S is Idle
@5
S is Processing
@10
S is Done
@enduml


' ========================
' MINDMAP
' ========================
@startmindmap
* Project
** Backend
** Frontend
** Database
@endmindmap


' ========================
' GANTT CHART
' ========================
@startgantt
title Gantt Example
[Task A] lasts 3 days
[Task B] lasts 2 days
[Task B] starts at [Task A]'s end
@endgantt


' ========================
' ER DIAGRAM (C4 / Entity style)
' ========================
@startuml
title ER Diagram Example
entity User {
  +id : int
  --
  name : string
}
entity Order {
  +id : int
}
User ||--o{ Order
@enduml
