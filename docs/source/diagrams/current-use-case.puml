@startuml CurrentUseCase
title Personalised News Aggregator - Current Use Cases (as implemented)
left to right direction

' ── Styling — matches use-case.puml for visual consistency ─────────────
skinparam DefaultFontName         "Segoe UI"
skinparam DefaultFontSize         12

skinparam Actor {
  BorderColor                     #1A252F
  BackgroundColor                 #D5E8D4
  FontStyle                       bold
  FontSize                        13
}

skinparam Usecase {
  BorderColor                     #1F618D
  BackgroundColor                 #EBF5FB
  BorderThickness                 1.5
  FontSize                        12
}

skinparam Rectangle {
  BorderColor                     #1A252F
  BorderThickness                 2
  BackgroundColor                 #FDFEFE
  FontStyle                       bold
  FontSize                        14
}

skinparam Arrow {
  Color                           #2C3E50
  FontSize                        11
  FontStyle                       italic
}

skinparam Note {
  BackgroundColor                 #FEF9E7
  BorderColor                     #F0B27A
}
' ────────────────────────────────────────────────────────

actor "Visitor" as Visitor
actor "User"    as User
Visitor <|-- User

rectangle "News Aggregator System" {

  ' Use case labels carry the real gateway-facing endpoint (all routes go through
  ' api-gateway, which StripPrefix=2 forwards to the backing service).

  ' --- Account Management (AuthController) ---
  usecase "Register Account\nPOST /api/users/auth/register" as UC11a
  usecase "Log In\nPOST /api/users/auth/login"              as UC11b

  ' --- Core Content Interaction (ArticleController) ---
  usecase "Browse Personalized Feed\nGET /api/content/articles" as UC1
  usecase "View Article\nGET /api/content/articles/{id}"        as UC12
  usecase "Search & Filter Articles\nGET /api/content/articles?q=&sourceId=&topicId=" as UC5

  ' --- Article Enhancements (gen-ai, all real endpoints) ---
  usecase "View AI Summary\nPOST /api/ai/summarize"           as UC2
  usecase "Get Concept Explanation\nPOST /api/ai/explain"     as UC3
  usecase "View Sentiment & Bias\nPOST /api/ai/sentiment"     as UC6
  usecase "Ask AI a Question (Q&A)\nPOST /api/ai/qa"          as UC13

  ' --- User Library (UserController + ArticleController) ---
  usecase "Save/Unsave Article\nPOST|DELETE /api/users/users/me/saved-articles/{articleId}" as UC7
  usecase "View Saved Articles\nPOST /api/content/articles/saved"                            as UC7b

  ' --- Preferences (UserController) ---
  usecase "Manage Topic Preferences\nPUT /api/users/users/me/settings"                    as UC14
  usecase "Subscribe/Unsubscribe Source\nPOST|DELETE /api/users/users/me/subscriptions/{sourceId}" as UC15

}

note right of UC15
  Sources are shared: Source.subscriberCount is
  tracked server-side; user-service calls
  content-service's /sources/{id}/subscribe with a
  client_credentials token (scope source.write), and
  a source is auto-removed once subscriberCount hits 0.
end note

note bottom of UC6
  SentimentResponse.bias is a categorical label
  (left | center | right | unclear), not a numeric
  score; the numeric SentimentResponse.score is
  sentiment polarity, not bias.
end note

' --- Actor Connections ---
Visitor --> UC11a
Visitor --> UC11b

User --> UC1
User --> UC5
User --> UC12
User --> UC7b
User --> UC14
User --> UC15

' --- Use Case Relationships ---
UC1 --> UC12  : <<include>>
UC5 --> UC12  : <<include>>

UC12 <.. UC2  : <<extend>>
UC12 <.. UC3  : <<extend>>
UC12 <.. UC6  : <<extend>>
UC12 <.. UC13 : <<extend>>
UC12 <.. UC7  : <<extend>>

note as N1
Scoped out relative to the initial plan (no backend, or removed):
Recommendations; Trending Topics (the web-client FeedSort
'trending' option only re-sorts the current page by
Article.readingMinutes client-side — no ranking endpoint);
Notifications (notifications-section.tsx is a disclaimed,
non-persisted mock); Auto-tag & Categorize (Article.topicId
exists and is filterable but RssFetcherService never sets it);
Bookmark Folders (UserSettings.savedArticleIds is a flat list).
end note
@enduml
